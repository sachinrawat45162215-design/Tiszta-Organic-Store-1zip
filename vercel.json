{
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @workspace/tiszta-organic run build",
  "outputDirectory": "artifacts/tiszta-organic/dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "BASE_PATH": "/"
  }
}
